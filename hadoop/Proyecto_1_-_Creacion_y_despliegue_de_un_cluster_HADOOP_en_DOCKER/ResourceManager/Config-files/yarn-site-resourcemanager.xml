<configuration>
<!-- Propiedades de configuración de YARN específicas del sitio -->
      <property>
        <!-- El nombre de host del ResourceManager -->
        <name>yarn.resourcemanager.hostname</name>
        <value>resourcemanager</value>
        <final>true</final>
      </property>
      
      <property>
        <!-- La asignación máxima para cada solicitud de contenedor en el RM en términos de núcleos virtuales de CPU (CPU cores). 
             Las peticiones superiores a este valor lanzarán una 
             InvalidResourceRequestException (valor por defecto 4) -->
        <name>yarn.scheduler.maximum-allocation-vcores</name>
        <value>1</value>
        <final>true</final>
      </property>

      <property>
        <!-- La asignación mínima de memoria para cada petición de contenedor en el RM en MBs. 
             Las peticiones de memoria inferiores a este valor se ajustarán al valor de esta propiedad. 
             Además, un NodeManager que esté configurado para tener menos memoria que este valor 
             será apagado por el ResourceManager (valor por defecto 1024) -->
        <name>yarn.scheduler.minimum-allocation-mb</name>
        <value>128</value>
        <final>true</final>
      </property>

      <property>
        <!-- La asignación máxima para cada solicitud de contenedor en el RM en MBs. 
             Las peticiones de memoria superiores a este valor lanzarán una 
             InvalidResourceRequestException (valor por defecto 8192) -->
        <name>yarn.scheduler.maximum-allocation-mb</name>
        <value>2560</value>
        <final>true</final>
      </property>
</configuration>

